# Port (Render setzt PORT automatisch)
PORT=3000

# JWT Secret – beliebig langen zufälligen String wählen
JWT_SECRET=ersetze-mich-mit-einem-geheimen-schluessel

# Bcrypt-Hash des Admin-Passworts
# Erstellen mit: node hash-password.js deinPasswort
ADMIN_PASSWORD_HASH=$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
